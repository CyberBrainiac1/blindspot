# Copy this file to .env for local development.
# Never commit .env with real values.

# Required only when running Qwen/Hack Club AI summaries directly.
HACKCLUB_AI_API_KEY=

# Optional Supabase upload configuration.
BLINDSPOT_SUPABASE_URL=
BLINDSPOT_SUPABASE_KEY=
BLINDSPOT_SUPABASE_BUCKET=photos
BLINDSPOT_SUPABASE_RIDES_TABLE=rides
BLINDSPOT_SUPABASE_PHOTOS_TABLE=photos
BLINDSPOT_SUPABASE_AUTOMATED_PHOTOS_TABLE=automated_photos
BLINDSPOT_SUPABASE_AI_SUMMARY_TABLE=ai_summary
BLINDSPOT_USER_ID=

# Optional ride summary service configuration.
BLINDSPOT_SUMMARY_SERVICE_URL=
BLINDSPOT_SUMMARY_SERVICE_TOKEN=

# Optional phone / BLE ride-control configuration.
BLINDSPOT_PHONE_BASE_URL=
BLINDSPOT_PHONE_TOKEN=
BLINDSPOT_BLE_ENABLED=0
BLINDSPOT_BLE_MODE=peripheral
BLINDSPOT_BLE_NAME=BlindSpot-Pi
BLINDSPOT_BLE_PHONE_NAME=Blind Spot

